# ============================================================
# OmniWallet — User Service Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Application ---
APP_NAME=user-service
APP_PORT=8081
APP_ENV=development   # development | production

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=omni_wallet_users
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---
# Use a long, randomly generated secret (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_very_long_and_random_secret_key
JWT_TTL=24h
