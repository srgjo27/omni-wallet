# ============================================================
# api-gateway — Environment Variables
# Copy to .env and update values for local development.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_NAME=api-gateway
APP_PORT=8080
APP_ENV=development

# JWT — must match the JWT_SECRET used by user-service and wallet-service
JWT_SECRET=dev-only-secret-replace-in-production-min-32-chars!!

# Redis — used for distributed rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Upstream service URLs
USER_SERVICE_URL=http://localhost:8081
WALLET_SERVICE_URL=http://localhost:8082

# Rate limiting — 60 requests per 60-second window per IP
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
