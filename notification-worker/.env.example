# ============================================================
# notification-worker — Environment Variables
# Copy to .env and update values for local development.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_NAME=notification-worker
APP_ENV=development

# RabbitMQ connection
RABBITMQ_URL=amqp://omni_user:omni_password@localhost:5672/

# RabbitMQ topology (defaults match wallet-service publisher settings)
RABBITMQ_EXCHANGE=omni.events
RABBITMQ_QUEUE=notification.worker.queue
RABBITMQ_ROUTING_KEY=transaction.#

# Per-worker in-flight message limit (QoS)
RABBITMQ_PREFETCH_COUNT=10
